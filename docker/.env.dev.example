# Скопируйте в docker/.env для docker-compose.dev.yml:
#   copy .env.dev.example .env
#
# Запуск: docker compose -f docker-compose.dev.yml --env-file .env up -d --build

POSTGRES_USER=omnisight
POSTGRES_PASSWORD=omnisight
POSTGRES_DB=omnisight
POSTGRES_PORT=5432

SECRET_KEY=change-me-in-development-only
API_KEY=omnisight-api-key-dev
WEBHOOK_SECRET=omnisight-webhook-secret-dev

CORS_ORIGINS=http://localhost:8080,http://localhost:5173

API_PORT=8000
WEB_PORT=8080
UVICORN_WORKERS=1
DATABASE_ASYNC_ENABLED=true
SEED_ON_START=1
