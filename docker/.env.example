# Copy to docker/.env and fill before: docker compose -f docker-compose.prod.yml --env-file .env up -d --build

POSTGRES_USER=omnisight
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=omnisight

# openssl rand -hex 32
SECRET_KEY=
API_KEY=
WEBHOOK_SECRET=

# First admin user (min 12 chars) — only applied on initial seed
ADMIN_INITIAL_PASSWORD=

# Public URL of the UI (for CORS)
CORS_ORIGINS=http://localhost:8080

WEB_PORT=8080
UVICORN_WORKERS=2
# CACHE_ENABLED=true — shared Postgres cache (cache_entries) for multi-worker
CACHE_ENABLED=true
DATABASE_ASYNC_ENABLED=true
SEED_ON_START=1
