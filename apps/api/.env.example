# --- Development (local) ---
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/omnisight
# Тесты используют отдельную БД omnisight_test (создаётся автоматически):
# TEST_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/omnisight_test

SECRET_KEY=
API_KEY=
WEBHOOK_SECRET=
# Leave empty in development — dev-only placeholders are injected automatically.
# For explicit local values:
# SECRET_KEY=change-me-in-development-only
# API_KEY=omnisight-api-key-dev
# WEBHOOK_SECRET=omnisight-webhook-secret-dev
WEBHOOK_URL=
INTEGRATION_USER_EMAIL=integration@omnisight.local
DATABASE_READ_URL=
# Optional read replica for async read pool (postgresql+asyncpg://...).
# Leave empty to use DATABASE_URL for all reads.
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=5

CACHE_TTL_SECONDS=30
# PostgreSQL: CACHE_ENABLED=true использует таблицу cache_entries (UTC TTL, multi-worker).
# Для нескольких API-реплик предпочтительнее REDIS_URL + CACHE_ENABLED=true.
# Отключить: CACHE_ENABLED=false
# ENSURE_SCHEMA_ON_START=false  # k8s: схема создаётся отдельным Job, не при старте каждого пода
# SKIP_DB_INIT=1               # e2e/скрипты: не трогать схему при старте uvicorn

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
LOG_JSON=false
DOCS_ENABLED=true

# --- Production (пример; лучше docker/.env для compose) ---
# APP_ENV=production
# LOG_JSON и DOCS_ENABLED принудительно true в production (§9 NFR, FR 43)
# CACHE_ENABLED=false
# SECRET_KEY=<openssl rand -hex 32>
# API_KEY=<openssl rand -hex 24>
# WEBHOOK_SECRET=<openssl rand -hex 24>
# CORS_ORIGINS=https://rsm.example.com
# TRUSTED_HOSTS=rsm.example.com,api.rsm.example.com
# ADMIN_INITIAL_PASSWORD=<strong-password-min-12-chars>
# RATE_LIMIT_MAX_REQUESTS=300
# AUTO_SYNC_SCHEDULER_ENABLED=true
# AUTO_SYNC_INTERVAL_SECONDS=300
# BACKGROUND_TASKS_ENABLED=false  # default in development; enable in worker / single-replica API
# WEBHOOK_SYNC_DELIVERY=true
# OUTBOX_POLL_INTERVAL_SECONDS=15
# OUTBOX_MAX_ATTEMPTS=5
# ENSURE_SCHEMA_ON_START=false  # k8s: схема через Job k8s/schema-job.yaml
# REDIS_URL=redis://redis:6379/0
DATABASE_ASYNC_ENABLED=true
# UVICORN_WORKERS=2
